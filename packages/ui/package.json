{
  "name": "@getpromptui/ui",
  "version": "0.2.0",
  "description": "PromptUI component library — React components referenced by @getpromptui/core",
  "keywords": [
    "promptui",
    "react",
    "components",
    "ui",
    "library",
    "shadcn",
    "headless"
  ],
  "homepage": "https://github.com/MartinLilt/ui-builder#readme",
  "bugs": {
    "url": "https://github.com/MartinLilt/ui-builder/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MartinLilt/ui-builder.git",
    "directory": "packages/ui"
  },
  "license": "MIT",
  "author": "Martin Li",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "react": "^18",
    "react-dom": "^18",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}