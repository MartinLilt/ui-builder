{
  "name": "@getpromptui/core",
  "version": "0.5.1",
  "description": "PromptUI preprocessor — compiles .promptui DSL into React or Vue templates",
  "keywords": [
    "promptui",
    "dsl",
    "preprocessor",
    "ui",
    "ai",
    "compiler",
    "react",
    "vue",
    "template",
    "codegen"
  ],
  "homepage": "https://github.com/MartinLilt/promptui#readme",
  "bugs": {
    "url": "https://github.com/MartinLilt/promptui/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MartinLilt/promptui.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "author": "Martin Li",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "promptui": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.mjs",
      "require": "./dist/vite.js"
    },
    "./skill.md": "./skill.md"
  },
  "files": [
    "dist",
    "skill.md",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "generate-skill": "tsx scripts/generate-skill.ts",
    "check-version": "tsx scripts/check-version.ts",
    "prepublishOnly": "pnpm check-version && pnpm generate-skill && pnpm build"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}